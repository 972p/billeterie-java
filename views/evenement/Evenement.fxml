<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" alignment="TOP_CENTER" prefHeight="500.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.evenement.EvenementController">
    
    <!-- Titre -->
    <children>
        <Label text="Évènements">
            <font>
                <Font size="33.0"/>
            </font>
        </Label>

        <!-- Barre d'actions (recherche + boutons) -->
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="event_field" promptText="Rechercher un évènement" prefWidth="250"/>
            <Button fx:id="create_event" text="Créer Évènement"/>
            <Button fx:id="show_event" text="Consulter Évènement"/>
        </HBox>

        <!-- TableView des évènements -->
        <TableView fx:id="event_table" prefHeight="300.0" prefWidth="580.0">
            <columns>
                <TableColumn fx:id="colTitre" text="Titre" prefWidth="200"/>
                <TableColumn fx:id="colDateDebut" text="Date début" prefWidth="180"/>
                <TableColumn fx:id="colLieu" text="Lieu" prefWidth="200"/>
            </columns>
        </TableView>

        <!-- Pagination manuelle -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="prevPage" text="Page précédente"/>
            <Label fx:id="labelPage" text="Page 1"/>
            <Button fx:id="nextPage" text="Page suivante"/>
        </HBox>
    </children>
</VBox>
