<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.evenement.SeatSelectionController">
   <children>
      <Label text="Sélectionnez vos places">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <HBox alignment="CENTER" spacing="5.0">
               <Rectangle width="15" height="15" fill="GREEN" arcWidth="5" arcHeight="5"/>
               <Label text="Disponible" />
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <Rectangle width="15" height="15" fill="RED" arcWidth="5" arcHeight="5"/>
               <Label text="Réservée" />
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <Rectangle width="15" height="15" fill="BLUE" arcWidth="5" arcHeight="5"/>
               <Label text="Sélectionnée" />
            </HBox>
         </children>
      </HBox>

      <Label text="SCÈNE" alignment="CENTER" style="-fx-background-color: #ddd; -fx-padding: 10 100;" maxWidth="Infinity"/>
      
      <!-- The grid where seats will be generated dynamically -->
      <GridPane fx:id="seatGrid" alignment="CENTER" hgap="10.0" vgap="10.0" />
      
      <HBox alignment="CENTER" spacing="20.0">
          <Button text="Retour" onAction="#handleReturn" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 10 20;"/>
          <Button text="Confirmer la réservation" onAction="#handleConfirmBooking" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-padding: 10 20;"/>
      </HBox>
   </children>
</VBox>
