<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" alignment="TOP_CENTER" prefHeight="500.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.evenement.EvenementController">

    <children>
        <!-- Titre -->
        <Label text="Évènements">
            <font>
                <Font size="33.0"/>
            </font>
        </Label>

        <!-- Barre d'actions (recherche + boutons) -->
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="event_field" promptText="Rechercher un évènement" prefWidth="250"/>
            <Button fx:id="reserve_event" text="Réserver une place (Plan)" />
            <Button fx:id="create_event" text="Créer Évènement"/>
            <Button fx:id="show_event" text="Consulter Évènement"/>
            <Button fx:id="edit_event" text="Modifier Évènement"/>
            <Button fx:id="delete_event" text="Supprimer Évènement"/>
            <Button fx:id="manage_users" text="Gestion Utilisateurs (Admin)"/>
            <Button fx:id="manage_reservations" text="Gestion Réservations (Admin)"/>
        </HBox>

        <!-- TableView des évènements -->
        <TableView fx:id="event_table" prefHeight="300.0" prefWidth="580.0">
            <columns>
                <TableColumn fx:id="colTitre" text="Titre" prefWidth="200"/>
                <!-- Temps en minutes -->
                <TableColumn fx:id="colTemps" text="Temps (min)" prefWidth="180"/>
                <!-- Description courte -->
                <TableColumn fx:id="colDescriptionCourte" text="Description courte" prefWidth="200"/>
            </columns>
        </TableView>

        <!-- Pagination manuelle -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="prevPage" text="Page précédente" onAction="#prevPage"/>
            <Label fx:id="labelPage" text="Page 1"/>
            <Button fx:id="nextPage" text="Page suivante" onAction="#nextPage"/>
        </HBox>
    </children>
</VBox>
