<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="400.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.auth.SignupController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
   </padding>

   <children>
      <Label text="Créer un compte">
         <font>
            <Font name="System Bold" size="24.0"/>
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>

      <TextField fx:id="nomField" promptText="Nom Complet" prefHeight="40.0" />
      <TextField fx:id="emailField" promptText="Adresse e-mail" prefHeight="40.0" />
      <TextField fx:id="telephoneField" promptText="Téléphone" prefHeight="40.0" />
      <TextField fx:id="adresseField" promptText="Adresse Postale" prefHeight="40.0" />
      <PasswordField fx:id="passwordField" promptText="Mot de passe" prefHeight="40.0" />
      <PasswordField fx:id="confirmPasswordField" promptText="Confirmer mot de passe" prefHeight="40.0" />

      <Label fx:id="errorLabel" textFill="RED" visible="false" />

      <VBox spacing="10" alignment="CENTER">
          <Button text="S'inscrire" onAction="#handleSignup" prefWidth="200.0" prefHeight="40.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" />
          <Button text="Retour à la connexion" onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: #007bff; -fx-underline: true;" />
      </VBox>

   </children>
</VBox>
