<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.admin.AdminReservationsController" spacing="20" alignment="CENTER" style="-fx-padding: 30; -fx-background-color: transparent;">
    
    <Label text="Gestion des Réservations" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
    
    <HBox spacing="20" alignment="CENTER">
        <javafx.scene.chart.PieChart fx:id="pieChartVentes" title="Billets vendus" prefWidth="350" prefHeight="250"/>
        <javafx.scene.chart.BarChart fx:id="barChartRevenus" title="Chiffre d'Affaires (€)" prefWidth="400" prefHeight="250">
            <xAxis><javafx.scene.chart.CategoryAxis label="Évènements" /></xAxis>
            <yAxis><javafx.scene.chart.NumberAxis label="Revenus (€)" /></yAxis>
        </javafx.scene.chart.BarChart>
    </HBox>

    <TableView fx:id="reservations_table" VBox.vgrow="ALWAYS" style="-fx-min-width: 800; -fx-min-height: 400;">
        <columns>
            <TableColumn fx:id="colEvent" text="Évènement" prefWidth="200" />
            <TableColumn fx:id="colDateHeure" text="Date &amp; Heure" prefWidth="150" />
            <TableColumn fx:id="colClient" text="Client" prefWidth="200" />
            <TableColumn fx:id="colPlace" text="Place" prefWidth="100" />
            <TableColumn fx:id="colDateAchat" text="Date d'Achat" prefWidth="150" />
            <TableColumn fx:id="colAction" text="Actions" prefWidth="150" />
        </columns>
    </TableView>

</VBox>
