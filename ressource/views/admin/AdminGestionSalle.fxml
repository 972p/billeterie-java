<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.admin.AdminGestionSalleController"
      spacing="30" style="-fx-padding: 30; -fx-background-color: transparent;">

    <!-- COLONNE GAUCHE : formulaire -->
    <VBox spacing="12" prefWidth="260" style="-fx-background-color: #2b2b3c; -fx-padding: 20; -fx-background-radius: 10;">
        <Label text="🏛 Créer une Salle" style="-fx-text-fill: #bb86fc; -fx-font-size: 18; -fx-font-weight: bold;"/>

        <Label text="Lieu :" style="-fx-text-fill: #cccccc;"/>
        <ComboBox fx:id="comboLieu" maxWidth="1.7976931348623157E308" promptText="Choisir un lieu"/>

        <Label text="Nom de la salle :" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="champNom" promptText="ex: Salle A"/>

        <Label text="Nombre de rangées :" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="champRangees" promptText="ex: 10"/>

        <Label text="Nombre de colonnes :" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="champColonnes" promptText="ex: 15"/>

        <Label fx:id="labelCapacite" text="Capacité totale : 0 places"
               style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 13;"/>

        <Button fx:id="btnSauvegarder" text="💾  Sauvegarder la salle"
                onAction="#handleSauvegarder"
                maxWidth="1.7976931348623157E308"
                styleClass="button-primary"/>
    </VBox>

    <!-- COLONNE DROITE : prévisualisation de la grille -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="Prévisualisation de la salle" style="-fx-text-fill: #bb86fc; -fx-font-size: 16; -fx-font-weight: bold;"/>
        <Label text="🎬 Écran" style="-fx-text-fill: #888; -fx-font-size: 12;" HBox.hgrow="ALWAYS"/>

        <ScrollPane fx:id="scrollGrille" fitToWidth="false" fitToHeight="false"
                    style="-fx-background-color: transparent; -fx-background: #1e1e2e;"
                    prefHeight="450" VBox.vgrow="ALWAYS">
            <GridPane fx:id="grillePreview" hgap="5" vgap="5" alignment="CENTER">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            </GridPane>
        </ScrollPane>
    </VBox>

</HBox>
