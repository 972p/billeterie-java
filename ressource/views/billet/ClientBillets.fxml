<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-padding: 30; -fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.billet.BilletController">
   <children>
      <Label text="Mes Billets" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 28;">
      </Label>
      <TableView fx:id="tableBillets" prefHeight="450.0" prefWidth="740.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colEvent" prefWidth="150.0" text="Évènement" />
          <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
          <TableColumn fx:id="colTime" text="Heure" />
          <TableColumn fx:id="colLieu" prefWidth="120.0" text="Lieu" />
          <TableColumn fx:id="colSalle" prefWidth="100.0" text="Salle" />
          <TableColumn fx:id="colSiege" prefWidth="120.0" text="Siège" />
          <TableColumn fx:id="colPrix" text="Prix (€)" />
          <TableColumn fx:id="colStatut" prefWidth="100.0" text="Statut" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleAnnulerBillet" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="Annuler le Billet" />
            <Button mnemonicParsing="false" onAction="#handleDownloadPdf" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Télécharger PDF" />
         </children>
      </HBox>
   </children>
</VBox>
