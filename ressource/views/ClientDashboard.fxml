            <Label text="Menu" textFill="#757575">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleViewProfile" styleClass="button-secondary" text="Mon Profil" />
