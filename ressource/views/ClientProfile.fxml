<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ClientProfileController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="900.0" style="-fx-padding: 10 20;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Mon Profil" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
         </children>
      </HBox>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 40;" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2b2b3c; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" maxWidth="500.0">
               <children>
                  <ImageView fx:id="profileImageView" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
                  <Button mnemonicParsing="false" onAction="#handleChangerPhoto" styleClass="button-secondary" text="Changer la photo" />
                  
                  <VBox spacing="10.0" style="-fx-padding: 20 0 0 0;" alignment="CENTER_LEFT" maxWidth="400.0">
                     <children>
                        <Label text="Informations Personnelles" style="-fx-font-weight: bold; -fx-font-size: 16;" textFill="#bb86fc" />
                        <HBox spacing="10.0">
                           <Label text="Nom :" style="-fx-font-weight: bold; -fx-text-fill: white;" prefWidth="100.0" />
                           <Label fx:id="lblNom" text="Chargement..." style="-fx-text-fill: #cccccc;" />
                        </HBox>
                        <HBox spacing="10.0">
                           <Label text="Email :" style="-fx-font-weight: bold; -fx-text-fill: white;" prefWidth="100.0" />
                           <Label fx:id="lblEmail" text="Chargement..." style="-fx-text-fill: #cccccc;" />
                        </HBox>
                        <HBox spacing="10.0">
                           <Label text="Téléphone :" style="-fx-font-weight: bold; -fx-text-fill: white;" prefWidth="100.0" />
                           <Label fx:id="lblTelephone" text="Chargement..." style="-fx-text-fill: #cccccc;" />
                        </HBox>
                        <HBox spacing="10.0">
                           <Label text="Adresse :" style="-fx-font-weight: bold; -fx-text-fill: white;" prefWidth="100.0" />
                           <Label fx:id="lblAdresse" text="Chargement..." wrapText="true" maxWidth="250.0" style="-fx-text-fill: #cccccc;" />
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
