<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" alignment="TOP_CENTER" prefHeight="500.0" prefWidth="600.0"
      style="-fx-background-color: transparent; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.evenement.EvenementController">

    <children>
        <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="20">
            <Label text="Évènements" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308">
                <font>
                    <Font size="33.0"/>
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btn_espace_client" text="Espace Client" style="-fx-background-color: #bb86fc; -fx-text-fill: white;" />
            <Button fx:id="btn_logout" text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: #dc3545; -fx-text-fill: white;" />
        </HBox>

        <!-- Barre d'actions (recherche + boutons) -->
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="event_field" promptText="Rechercher un évènement" prefWidth="250"/>
            <ComboBox fx:id="cbFilterCategorie" promptText="Toutes les catégories" />
            <Button fx:id="reserve_event" text="Réserver une place (Plan)" />
            <Button fx:id="create_event" text="Créer Évènement"/>
            <Button fx:id="show_event" text="Consulter Évènement"/>
            <Button fx:id="edit_event" text="Modifier Évènement"/>
            <Button fx:id="delete_event" text="Supprimer Évènement"/>
            <Button fx:id="manage_users" text="Gestion Utilisateurs (Admin)"/>
            <Button fx:id="manage_reservations" text="Gestion Réservations (Admin)"/>
        </HBox>

        <!-- Vue sous forme de cartes -->
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
           <content>
              <FlowPane fx:id="event_container" alignment="TOP_CENTER" hgap="30.0" prefWrapLength="900.0" rowValignment="TOP" styleClass="event-container" vgap="30.0" />
           </content>
        </ScrollPane>

        <!-- Pagination manuelle -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="prevPage" text="Page précédente" onAction="#prevPage"/>
            <Label fx:id="labelPage" text="Page 1"/>
            <Button fx:id="nextPage" text="Page suivante" onAction="#nextPage"/>
        </HBox>
    </children>
</VBox>
