<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: transparent; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.evenement.SeatSelectionController">
   <children>
      <Label text="Sélectionnez vos places" style="-fx-text-fill: white;">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <HBox alignment="CENTER" spacing="5.0">
               <Rectangle width="15" height="15" fill="#2b2b3c" stroke="#bb86fc" arcWidth="5" arcHeight="5"/>
               <Label text="Disponible" style="-fx-text-fill: white;" />
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <Rectangle width="15" height="15" fill="#dc3545" arcWidth="5" arcHeight="5"/>
               <Label text="Réservée" style="-fx-text-fill: white;" />
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <Rectangle width="15" height="15" fill="#bb86fc" arcWidth="5" arcHeight="5"/>
               <Label text="Sélectionnée" style="-fx-text-fill: white;" />
            </HBox>
         </children>
      </HBox>

      <Label text="SCÈNE" alignment="CENTER" style="-fx-background-color: #2b2b3c; -fx-text-fill: white; -fx-padding: 10 100;" maxWidth="Infinity"/>
      
      <!-- The grid where seats will be generated dynamically -->
      <GridPane fx:id="seatGrid" alignment="CENTER" hgap="10.0" vgap="10.0" />
      
      <HBox alignment="CENTER" spacing="20.0">
          <Button text="Retour" onAction="#handleReturn" styleClass="button-secondary"/>
          <Button text="Confirmer la réservation" onAction="#handleConfirmBooking" styleClass="button-primary"/>
      </HBox>
   </children>
</VBox>
